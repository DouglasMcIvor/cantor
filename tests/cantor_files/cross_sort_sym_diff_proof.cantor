-- Cross-sort symmetric difference (^): the LHS and RHS may have genuinely
-- different CVC5 sorts. See tests/solver/set_ops.rs for the full semantics
-- writeup; both cases exercised here should be proved and, via `main`,
-- actually run through codegen/JIT (`cantor run`).

-- Nat* ^ Int: a Kleene-star sequence bridged with a scalar sharing its
-- element kind via sequence unification. Subtracting Int removes every
-- length-1 sequence (the only ones with an Int interpretation), and {[]}
-- removes the length-0 case, leaving length >= 2 — safe for xs[0] + xs[1].
kleene_sym_diff : (Nat* ^ Int) - Int - {[]} -> Nat
kleene_sym_diff(xs) = xs[0] + xs[1]

-- Bool and Nat share no representable value (no implicit 0/1 conversion), so
-- `Bool ^ Nat` is a tagged union exactly like `Bool | Nat`.
pick_bool : -> Bool ^ Nat
pick_bool() = true

pick_nat : -> Bool ^ Nat
pick_nat() = 5

-- kleene_sym_diff([1, 2, 3]) = 1 + 2 = 3; both pick_* checks add 10 and 100.
main : -> Int
main() = kleene_sym_diff([1, 2, 3]) + (if pick_bool() in Bool then 10 else 0) + (if pick_nat() in Nat then 100 else 0)
