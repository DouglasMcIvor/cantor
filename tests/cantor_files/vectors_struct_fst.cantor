-- Verify literal bracket-index + dot-projection on a struct vector:
--   [(1,10),(2,20),(3,30)][0].0 = 1  and  [(1,10),(2,20),(3,30)][2].1 = 30
--
-- A literal array has tuple sort in the solver (not sequence sort), so the
-- projection is resolved via ApplySelector without a runtime bounds obligation.

first_fst : -> Nat
first_fst() = [(1, 10), (2, 20), (3, 30)][0].0

third_snd : -> Nat
third_snd() = [(1, 10), (2, 20), (3, 30)][2].1

main : -> Nat
main() = first_fst()
