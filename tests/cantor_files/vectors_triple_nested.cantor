-- Triple-nested vector tests: Nat*** (vector of Nat** elements).

-- Build a Nat*** from a literal triple-nesting.
make_triple : -> Nat***
make_triple() = [[[1, 2], [3]], [[4, 5, 6]]]

-- Outer length: number of Nat** elements.
outer_len : Nat*** -> Nat
outer_len(xsss) = len(xsss)

-- Middle length: len(xsss[i]).
middle_len : Nat*** -> Nat
middle_len(xsss) {
    i : Nat = 0
    return len(xsss[i])
}

-- Deep scalar access: xsss[1][0][2] on [[[1,2],[3]],[[4,5,6]]] = 6.
get_deep : -> Nat
get_deep() {
    xsss : Nat*** = [[[1, 2], [3]], [[4, 5, 6]]]
    i : Nat = 1
    j : Nat = 0
    k : Nat = 2
    return xsss[i][j][k]
}

-- Concatenation of two Nat*** vectors.
concat_triple : -> Nat
concat_triple() {
    xs : Nat*** = [[[1, 2]], [[3]]]
    ys : Nat*** = [[[4, 5, 6]]]
    zs : Nat*** = xs ++ ys
    return len(zs)
}

main : -> Nat
main() = get_deep()
