-- Builtin `show` on a genuine multi-arm TaggedUnion (not the specialized
-- `T | Fail`/`T | None` wire shape) is not yet implemented — must fail
-- loudly with `CompileError::Unsupported`, not silently misbehave.
f : Int -> (Int * Int) | Int
f(x) = if x == 0 then (1, 2) else 3

main : -> Char*
main() {
    a : (Int * Int) | Int = f(0)
    show(a)
}
