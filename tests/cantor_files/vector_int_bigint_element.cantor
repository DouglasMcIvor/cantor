-- Vector(Int) elements are documented as deliberately out of scope for
-- arbitrary-precision support (int-soundness-plan.md, step 4b's
-- "Vector(Int)/Set(Int)/runtime-Set for-loop storage" entry): an element
-- that doesn't fit raw i64 aborts loudly (a container-specific message, see
-- `cantor_bigint_to_i64_container`) rather than computing the correct
-- (BigInt-backed) answer or, worse, silently corrupting it. See
-- tests/cli/bigint.rs's container-elements comment block for the full
-- history (this was briefly, unsoundly "fixed" by skipping the boundary
-- conversion instead, then reverted once that broke local vector-let
-- bindings elsewhere).
big : -> Int
big() = 4611686018427387904 * 2

get0 : (Int* - Int - {[]}) -> Int
get0(xs) = xs[0]

make_vec : -> (Int* - Int - {[]})
make_vec() = [big(), 1]

main : -> Int
main() = get0(make_vec())
