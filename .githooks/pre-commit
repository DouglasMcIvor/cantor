#!/usr/bin/env bash
# Blocks the commit if any staged Rust file isn't `cargo fmt`-clean.
# Enable with: git config core.hooksPath .githooks
set -euo pipefail

if ! cargo fmt --all -- --check; then
    echo
    echo "pre-commit: formatting check failed. Run 'cargo fmt' and re-stage." >&2
    exit 1
fi
